<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_survey_question_import_wizard_form" model="ir.ui.view">
        <field name="name">survey.question.import.wizard.form</field>
        <field name="model">survey.question.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Certification Questions">
                <group>
                    <field name="survey_id"/>
                    <field name="import_file" filename="import_filename"/>
                    <field name="import_filename" invisible="1"/>
                    <field name="replace_existing"/>
                </group>
                <group>
                    <div class="o_form_label">Supported columns</div>
                    <div>
                        <p><code>Section</code>, <code>Title</code>, <code>Question Type</code>, <code>Description</code>, <code>Mandatory</code></p>
                        <p><code>Answer 1</code>, <code>Correct 1</code>, <code>Score 1</code>, <code>Answer 2</code>, ...</p>
                        <p><code>Correct Value</code>, <code>Score</code>, <code>Scale Min</code>, <code>Scale Max</code></p>
                        <p class="text-warning mb-0">If "Replace Existing Questions" is checked, all current certification questions and sections will be removed before import.</p>
                    </div>
                </group>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"/>
                    <a href="/slides_survey/certification/import_template" target="_blank" class="btn btn-secondary" role="button">
                        Download Template
                    </a>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_survey_question_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Certification Questions</field>
        <field name="res_model">survey.question.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_survey_question_import_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
